# Production Environment Variables Example
# Copy this file to .env and update with your secure values

# Airflow Project Configuration
AIRFLOW_PROJ_DIR=.
AIRFLOW_UID=50000

# Airflow Security Keys (CRITICAL - Generate new keys for each environment)
# Generate Keys Commands:
    # Fernet Key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
    # Secret Key: python -c "import secrets; print(secrets.token_hex(32))"
AIRFLOW__CORE__FERNET_KEY=YOUR_FERNET_KEY_HERE
AIRFLOW__API__SECRET_KEY=YOUR_API_SECRET_KEY_HERE
AIRFLOW__API_AUTH__JWT_SECRET=YOUR_API_AUTH_JWT_SECRET_HERE
